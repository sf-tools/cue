{
  "name": "cue",
  "version": "0.0.5",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "gen:version": "bun scripts/generate-version.mjs",
    "dev": "bun gen:version && bun --watch src/cue.ts",
    "start": "bun gen:version && bun src/cue.ts",
    "build": "bun gen:version && bun build src/cue.ts --target node --outdir dist"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@pydantic/genai-prices": "^0.0.56",
    "@zenbase/llml": "^0.4.0",
    "ai": "^6.0.160",
    "approximate-number": "^3.0.1",
    "chalk": "^5.6.2",
    "dedent": "^1.7.2",
    "fuse.js": "^7.3.0",
    "log-update": "^8.0.0",
    "ora": "^9.3.0",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/approximate-number": "^2.1.0",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14"
  }
}
