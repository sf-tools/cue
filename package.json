{
  "name": "@sf-tools/cue",
  "version": "0.0.24",
  "description": "Your next move, on cue.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cue.js",
  "bin": {
    "cue": "./dist/cue.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sf-tools/cue.git"
  },
  "homepage": "https://github.com/sf-tools/cue#readme",
  "bugs": {
    "url": "https://github.com/sf-tools/cue/issues"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "gen:version": "bun scripts/generate-version.mjs",
    "dev": "bun gen:version && bun --watch src/cue.ts",
    "start": "bun gen:version && bun src/cue.ts",
    "build": "bun gen:version && bun scripts/build.mjs",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@pydantic/genai-prices": "^0.0.56",
    "ai": "^6.0.160",
    "approximate-number": "^3.0.1",
    "chalk": "^5.6.2",
    "dedent": "^1.7.2",
    "fuse.js": "^7.3.0",
    "isomorphic-git": "^1.37.5",
    "log-update": "^8.0.0",
    "markdown-it": "^14.1.1",
    "open-simplex-noise": "^2.5.0",
    "ora": "^9.3.0",
    "prismjs": "^1.30.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/approximate-number": "^2.1.0",
    "@types/bun": "^1.3.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.6",
    "esbuild": "^0.28.0"
  },
  "trustedDependencies": [
    "@homebridge/node-pty-prebuilt-multiarch"
  ]
}
